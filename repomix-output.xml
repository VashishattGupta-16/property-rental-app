from django.shortcuts import redirect
from django.urls import reverse
from django.http import HttpResponse, HttpResponsePermanentRedirect
from django.conf import settings
from django.utils.cache import patch_vary_headers
import logging

logger = logging.getLogger(__name__)


class UptimeRobotMiddleware:
    """
    Intercepts UptimeRobot health checks and returns a 200 OK response immediately
    to avoid processing the full Django request lifecycle and generating verbose logs.
    """
    def __init__(self, get_response):
        self.get_response = get_response

    def __call__(self, request):
        user_agent = request.META.get('HTTP_USER_AGENT', '')
        if 'UptimeRobot' in user_agent:
            return HttpResponse("OK")
        return self.get_response(request)


class ProfileCompletionMiddleware:
    """
    Ensures that users complete their profile before accessing other parts of the site.
    """
    def __init__(self, get_response):
        self.get_response = get_response
        # Pre-resolve static route names to paths to avoid regex overhead per request
        self.allowed_route_names = [
            'profile_setup', 'account_logout', 'offline', 'manifest', 'service_worker'
        ]
        self.protected_path_prefixes = (
            '/accounts/',
            settings.STATIC_URL,
            settings.MEDIA_URL,
        )

    def __call__(self, request):
        if request.user.is_authenticated and not request.user.is_staff:
            # If the profile is incomplete, redirect to the setup page,
            if not request.user.profile_is_complete():
                allowed_paths = [reverse(name) for name in self.allowed_route_names]

                # Allow access to static/media, accounts, PWA files, and API/AJAX requests
                is_allowed_path = (
                    request.path in allowed_paths
                    or request.path.startswith(self.protected_path_prefixes)
                    or request.headers.get('x-requested-with') == 'XMLHttpRequest'
                    or 'application/json' in request.headers.get('Accept', '')
                )

                if not is_allowed_path:
                    return redirect('profile_setup')

        return self.get_response(request)


class HtmxVaryMiddleware:
    """
    When the same URL can return either a full page or a fragment depending on
    HTMX headers, caches must key on those headers to avoid mixing variants.
    """

    def __init__(self, get_response):
        self.get_response = get_response

    def __call__(self, request):
        response = self.get_response(request)

        content_type = response.get("Content-Type", "")
        if isinstance(content_type, str) and content_type.lower().startswith("text/html"):
            patch_vary_headers(response, ("HX-Request", "HX-History-Restore-Request"))

        return response
</file>

<file path="tweet/templates/rental_form.html">
{% extends base_template %}
{% load media_urls %}

{% block content %}
<style>
    /* Stepper Styles */
    .step-content { display: none; }
    .step-content.active { display: block; animation: fadeIn 0.4s ease-in-out; }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .step-indicator.active { color: var(--accent); border-color: var(--accent); }
    .step-indicator.completed { color: #10b981; border-color: #10b981; }

    .input-error {
        border-color: #f87171 !important;
        box-shadow: 0 0 0 4px rgba(248, 113, 113, 0.1) !important;
    }
</style>

<div class="max-w-4xl mx-auto py-12 px-4">
    
    <!-- HEADER & PROGRESS -->
    <div class="mb-12">
        <h1 class="text-4xl font-black text-white mb-8">
            {% if form.instance.pk %} Edit <span class="text-blue-500">Property</span> {% else %} Create <span class="text-blue-500">Listing</span> {% endif %}
        </h1>
        
        <!-- Progress Bar -->
        <div class="flex items-center justify-between relative">
            <div class="absolute h-1 bg-gray-700 w-full top-1/2 -z-10"></div>
            <div id="progress-line" class="absolute h-1 bg-[var(--accent)] transition-all duration-500 top-1/2 -z-10" style="width: 0%;"></div>
            
            <div class="step-indicator active w-10 h-10 rounded-full glass-card border-2 flex items-center justify-center font-bold text-white bg-slate-900" data-step="1">1</div>
            <div class="step-indicator w-10 h-10 rounded-full glass-card border-2 flex items-center justify-center font-bold text-white bg-slate-900" data-step="2">2</div>
            <div class="step-indicator w-10 h-10 rounded-full glass-card border-2 flex items-center justify-center font-bold text-white bg-slate-900" data-step="3">3</div>
        </div>
        <div class="flex justify-between mt-2 text-[10px] font-black uppercase tracking-widest text-gray-500">
            <span>Core Info</span>
            <span>Details</span>
            <span>Gallery</span>
        </div>
    </div>

    <form id="multiStepForm" method="post" enctype="multipart/form-data" class="space-y-8" novalidate>
        {% csrf_token %}
        {{ formset.management_form }}

        {# Global error banner #}
        {% if form.errors or formset.errors %}
        <div data-errors class="mb-6 p-4 rounded-xl border border-red-500/50 bg-red-500/10 glass-card">
            <div class="flex items-start gap-3">
                <i class="fa-solid fa-circle-exclamation text-red-500 mt-1 shrink-0"></i>
                <div>
                    <p class="text-sm font-black text-red-400 mb-2 uppercase tracking-widest">
                        Validation errors detected:
                    </p>
                    <ul class="list-disc list-inside space-y-1">
                        {# Form field errors #}
                        {% for field in form %}
                            {% for error in field.errors %}
                                <li class="text-[10px] font-bold text-red-400 uppercase">
                                    <span class="opacity-60">{{ field.label }}:</span> {{ error }}
                                </li>
                            {% endfor %}
                        {% endfor %}

                        {# Non-field errors #}
                        {% for error in form.non_field_errors %}
                            <li class="text-[10px] font-bold text-red-400 uppercase">{{ error }}</li>
                        {% endfor %}

                        {# Formset errors #}
                        {% if formset %}
                            {% for fs_form in formset %}
                                {% for field in fs_form %}
                                    {% for error in field.errors %}
                                        <li class="text-[10px] font-bold text-red-400 uppercase">
                                            <span class="opacity-60">Image {{ forloop.parentloop.counter }} - {{ field.label }}:</span> {{ error }}
                                        </li>
                                    {% endfor %}
                                {% endfor %}
                            {% endfor %}
                        {% endif %}
                    </ul>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- STEP 1: CORE INFO -->
        <div class="step-content active" id="step1">
            <div class="glass-card rounded-3xl p-8">
                <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-house text-blue-500"></i> Primary Information
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.title.label }}</label>
                        <div class="contents">{{ form.title }}</div>
                        <div class="error-container">
                            {% if form.title.errors %}
                                <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight mt-1 flex items-center gap-1">
                                    <i class="fa-solid fa-triangle-exclamation"></i> {{ form.title.errors.0 }}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.location.label }}</label>
                        <div class="contents">{{ form.location }}</div>
                        <div class="error-container">
                            {% if form.location.errors %}
                                <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight mt-1 flex items-center gap-1">
                                    <i class="fa-solid fa-triangle-exclamation"></i> {{ form.location.errors.0 }}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex flex-col md:col-span-2 gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.description.label }}</label>
                        <div class="contents">{{ form.description }}</div>
                        <div class="error-container">
                            {% if form.description.errors %}
                                <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight mt-1 flex items-center gap-1">
                                    <i class="fa-solid fa-triangle-exclamation"></i> {{ form.description.errors.0 }}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 2: PRICING & TYPE -->
        <div class="step-content" id="step2">
            <div class="glass-card rounded-3xl p-8">
                <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-tag text-blue-500"></i> Pricing & Specifications
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.price.label }}</label>
                        <div class="contents">{{ form.price }}</div>
                        <div class="error-container">
                            {% if form.price.errors %}
                                <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight mt-1 flex items-center gap-1">
                                    <i class="fa-solid fa-triangle-exclamation"></i> {{ form.price.errors.0 }}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-black text-xs font-bold uppercase mb-2">{{ form.property_type.label }}</label>
                        <div class="contents">{{ form.property_type }}</div>
                        <div class="error-container">
                            {% if form.property_type.errors %}
                                <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight mt-1 flex items-center gap-1">
                                    <i class="fa-solid fa-triangle-exclamation"></i> {{ form.property_type.errors.0 }}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                    {% for field in form %}
                        {% if field.name not in "title location description price property_type" %}
                            <div class="flex flex-col gap-1">
                                <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ field.label }}</label>
                                <div class="contents">{{ field }}</div>
                                <div class="error-container">
                                    {% if field.errors %}
                                        <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight mt-1 flex items-center gap-1">
                                            <i class="fa-solid fa-triangle-exclamation"></i> {{ field.errors.0 }}
                                        </p>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- STEP 3: GALLERY -->
        <div class="step-content" id="step3">
            <div class="glass-card rounded-3xl p-8">
                <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-images text-blue-500"></i> Visual Media
                </h2>
                <p class="text-gray-500 text-sm mb-6 italic">Upload up to 3 additional images to showcase the space.</p>
                <div class="grid grid-cols-1 gap-4">
                    {% if formset.non_form_errors %}
                        <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/30 mb-4 animate-pulse">
                            {% for error in formset.non_form_errors %}
                                <p class="text-red-400 text-xs font-bold uppercase tracking-tight">⚠ {{ error }}</p>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {% if formset.errors %}
                        <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/30 mb-4">
                            {% for errors in formset.errors %}
                                {% for field, error in errors.items %}<p class="text-red-400 text-[10px] font-black">{{ error }}</p>{% endfor %}
                            {% endfor %}
                        </div>
                    {% endif %}
                    {% for form_img in formset %}
                        <div class="p-4 border border-white/5 rounded-2xl bg-white/5 royal-input">
                            {% for hidden in form_img.hidden_fields %}{{ hidden }}{% endfor %}
                            <div class="flex flex-col gap-1">
                                {{ form_img.image }}
                                <div class="error-container">
                                    {% if form_img.image.errors %}<p class="text-red-400 text-[10px] font-bold uppercase tracking-tight mt-1 flex items-center gap-1"><i class="fa-solid fa-triangle-exclamation"></i> {{ form_img.image.errors.0 }}</p>{% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- NAVIGATION BUTTONS -->
        <div class="flex justify-between items-center pt-8">
            <button type="button" id="prevBtn" class="hidden px-8 py-3 rounded-xl border border-white/10 text-white font-bold hover:bg-white/5 transition-all">
                Previous
            </button>
            <div class="ml-auto flex gap-4">
                <button type="button" id="nextBtn" class="px-10 py-4 bg-[var(--accent)] text-white font-black rounded-xl shadow-lg hover:opacity-90 transition-all">
                    Next Step
                </button>
                <button type="submit" id="submitBtn" class="hidden px-10 py-4 bg-[var(--accent)] text-white font-black rounded-xl shadow-lg hover:opacity-90 transition-all">
                    {% if form.instance.pk %}Update Listing{% else %}Publish Listing{% endif %}
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    const steps = Array.from(document.querySelectorAll('.step-content'));
    const indicators = document.querySelectorAll('.step-indicator');
    const form = document.getElementById('multiStepForm');
    const progressLine = document.getElementById('progress-line');
    const nextBtn = document.getElementById('nextBtn');
    const prevBtn = document.getElementById('prevBtn');
    const submitBtn = document.getElementById('submitBtn');
    let currentStep = 0;

    function showError(input, message) {
        const container = input.closest('.flex.flex-col') || input.parentElement;
        input.classList.add('input-error');
        
        let errorContainer = container.querySelector('.error-container');
        if (!errorContainer) {
            errorContainer = document.createElement('div');
            errorContainer.className = 'error-container';
            container.appendChild(errorContainer);
        }
        
        let errorMsg = errorContainer.querySelector('.js-error-msg');
        if (!errorMsg) {
            errorMsg = document.createElement('p');
            errorMsg.className = 'js-error-msg text-red-400 text-[10px] font-bold uppercase tracking-tight mt-1 flex items-center gap-1';
            errorContainer.appendChild(errorMsg);
        }
        errorMsg.innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i> ${message}`;
    }

    function clearError(input) {
        const container = input.closest('.flex.flex-col') || input.parentElement;
        input.classList.remove('input-error');
        const errorMsg = container.querySelector('.js-error-msg');
        if (errorMsg) errorMsg.remove();
    }

    function validateStep(stepIndex) {
        const currentStepEl = steps[stepIndex];
        const inputs = currentStepEl.querySelectorAll('input[required], select[required], textarea[required]');
        let isValid = true;
        let firstInvalidEl = null;

        inputs.forEach(input => {
            const value = input.value.trim();
            if (!value) {
                isValid = false;
                showError(input, 'This field is required');
                if (!firstInvalidEl) firstInvalidEl = input;
            } else {
                clearError(input);
            }
        });

        if (!isValid && firstInvalidEl) {
            firstInvalidEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            firstInvalidEl.focus();
        }

        return isValid;
    }

    function updateStep() {
        steps.forEach((step, index) => {
            step.classList.toggle('active', index === currentStep);
        });

        indicators.forEach((ind, index) => {
            ind.classList.toggle('active', index === currentStep);
            ind.classList.toggle('completed', index < currentStep);
        });

        progressLine.style.width = (currentStep / (steps.length - 1)) * 100 + "%";

        // Button Visibility
        prevBtn.classList.toggle('hidden', currentStep === 0);
        
        if (currentStep === steps.length - 1) {
            nextBtn.classList.add('hidden');
            submitBtn.classList.remove('hidden');
        } else {
            nextBtn.classList.remove('hidden');
            submitBtn.classList.add('hidden');
        }
    }

    nextBtn.addEventListener('click', () => {
        if (validateStep(currentStep)) {
            currentStep++;
            updateStep();
        }
    });

    form.querySelectorAll('input, select, textarea').forEach(input => {
        input.addEventListener('input', () => {
            if (input.value.trim()) clearError(input);
        });
    });

    prevBtn.addEventListener('click', () => {
        if (currentStep > 0) {
            currentStep--;
            updateStep();
        }
    });

    form.addEventListener('submit', (e) => {
        // Final validation across all steps
        let allValid = true;
        for (let i = 0; i < steps.length; i++) {
            if (!validateStep(i)) {
                allValid = false;
                currentStep = i;
                updateStep();
                e.preventDefault();
                break;
            }
        }
    });

    // Server-side error handling: find the first field with a Django error and jump to that step
    window.addEventListener('load', () => {
        // Auto-scroll to error banner if it exists
        const errorBanner = document.querySelector('[data-errors]');
        if (errorBanner) {
            errorBanner.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // Step management for errors
        const firstServerSideError = document.querySelector('.error-container p');
        if (firstServerSideError) {
            const targetStep = firstServerSideError.closest('.step-content');
            // Highlight field with server-side error
            const container = firstServerSideError.closest('.flex.flex-col');
            if (container) {
                const input = container.querySelector('input, select, textarea');
                if (input) input.classList.add('input-error');
            }
            if (targetStep) {
                currentStep = steps.indexOf(targetStep);
                updateStep();
            }
        }
    });
</script>
{% endblock %}
</file>

