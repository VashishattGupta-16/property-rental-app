<script>
// ─── Navbar: Event Delegation ──────────────────────────────────────────────
// Uses document-level delegation so it works after HTMX swaps,
// browser back/forward, and bfcache restores — no re-init needed.
(function () {

    // ── Close all open dropdowns ─────────────────────────────
    function closeAll() {
        document.querySelectorAll('.js-dropdown-menu.show-dropdown').forEach(m => {
            m.classList.remove('show-dropdown');
        });
        document.querySelectorAll('.js-dropdown-btn[aria-expanded="true"]').forEach(b => {
            b.setAttribute('aria-expanded', 'false');
        });
    }

    // ── Toggle a specific dropdown ───────────────────────────
    function toggleDropdown(btn) {
        const menu = btn.closest('.dropdown-container')
                        ?.querySelector('.js-dropdown-menu');
        if (!menu) return;

        const isOpen = menu.classList.contains('show-dropdown');

        // Close everything first
        closeAll();

        // Open this one if it was closed
        if (!isOpen) {
            menu.classList.add('show-dropdown');
            btn.setAttribute('aria-expanded', 'true');
        }
    }

    // ── Toggle accordion ─────────────────────────────────────
    function toggleAccordion(btn) {
        const content = btn.closest('.accordion')?.querySelector('.accordion-content');
        if (!content) return;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        content.toggleAttribute('hidden', isOpen);
    }

    // ── Single delegated click handler on document ───────────
    // Attached ONCE — survives all HTMX swaps and back navigation
    if (!window.__navDelegated) {
        window.__navDelegated = true;

        document.addEventListener('click', function (e) {

            // Dropdown trigger button
            const dropBtn = e.target.closest('.js-dropdown-btn');
            if (dropBtn) {
                e.stopPropagation();
                toggleDropdown(dropBtn);
                return;
            }

            // Accordion button
            const accBtn = e.target.closest('.accordion-btn');
            if (accBtn) {
                e.preventDefault();
                e.stopPropagation();
                toggleAccordion(accBtn);
                return;
            }

            // Click outside — close all
            if (!e.target.closest('.dropdown-container')) {
                closeAll();
            }
        });

        // Close on Escape
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeAll();
        });

        // Close on HTMX navigation start
        document.addEventListener('htmx:beforeRequest', closeAll);

        // Close on browser back/forward
        window.addEventListener('popstate', closeAll);
    }

})();
</script>
