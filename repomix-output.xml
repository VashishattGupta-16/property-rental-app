set -o errexit

python - <<'PY'
from pathlib import Path
p = Path('requirements.txt')
raw = p.read_bytes()
try:
    raw.decode('utf-8')
except UnicodeDecodeError:
    txt = raw.decode('utf-16')
    p.write_text(txt, encoding='utf-8')
PY

