{% block extra_scripts %}
<script>
  function initRevealAnimations() {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const container = document.getElementById('main-content') || document.body;

    // Optimized: Only query for elements within the swapped container that haven't been shown
    const revealEls = Array.from(container.querySelectorAll(".reveal:not(.is-inview)"));
    if (reduceMotion) {
      revealEls.forEach(el => el.classList.add("is-inview"));
    } else if (revealEls.length) {
      const io = new IntersectionObserver((entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target.classList.add("is-inview");
          obs.unobserve(entry.target);
        }
      }, { threshold: 0.01, rootMargin: "0px 0px 100px 0px" });
      revealEls.forEach(el => io.observe(el));
    }
  }

  // Run on initial load and after every HTMX swap
  initRevealAnimations();
  document.body.addEventListener('htmx:afterSettle', initRevealAnimations);

  (function () {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Parallax (subtle, no gaps)
    if (reduceMotion) return;

    const container = document.getElementById('main-content') || document.body;
    const items = Array.from(container.querySelectorAll("[data-parallax]"))
      .map(el => ({
        el,
        img: el.querySelector("img"),
        speed: Number.parseFloat(el.dataset.speed || "0.10"),
        max: Number.parseFloat(el.dataset.max || "160"),
      }))
      .filter(item => item.img && !Number.isNaN(item.speed) && !Number.isNaN(item.max));

    if (!items.length) return;

    // Prime images so we never reveal empty space during parallax on small screens.
    for (const item of items) {
      item.img.style.objectPosition = "50% 50%";
      item.img.style.willChange = "translate";
    }

    let ticking = false;

    function update() {
      const vh = window.innerHeight || 1;
      const intensity = 4;

      for (const item of items) {
        const rect = item.el.getBoundingClientRect();
        if (!rect.height) continue;
        const centerDiff = (rect.top + rect.height / 2) - vh / 2;
        const progress = centerDiff / vh;

        const desiredRange = Math.min(item.max, item.max * item.speed * intensity);

        // Images use `scale-110`, so the safe translate range is ~5% of the container height.
        // Clamp to that to avoid the "half image / empty gap" issue on small screens.
        const safeRange = Math.max(0, rect.height * 0.05 - 1);
        const range = Math.min(desiredRange, safeRange);
        const offset = Math.max(-range, Math.min(range, -progress * range));

        item.img.style.translate = `0px ${Math.round(offset)}px`;
      }
      ticking = false;
    }

    function requestTick() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(update);
    }

    window.addEventListener("scroll", requestTick, { passive: true });
    window.addEventListener("resize", requestTick);
    requestTick();
  })();
</script>
{% endblock %}
