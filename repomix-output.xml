                <p class="text-slate-400 text-[10px] sm:text-[11px] flex items-center gap-1.5 mb-3 truncate">

                    <i class="fa-solid fa-location-dot text-blue-500 text-[9px]"></i>

                    {{ rental.location|default:"Location not available" }}

                </p>

                <!-- FOOTER -->
                <div class="flex justify-between items-center border-t border-white/5 pt-3 sm:pt-4">

                    <!-- PRICE -->
                    <div>

                        <p class="text-[7px] sm:text-[8px] font-black text-slate-500 uppercase tracking-widest">
