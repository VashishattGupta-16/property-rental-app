/* RESPONSIVE */
@media(max-width:900px){

.hero-grid,
.showcase-grid,
.team-grid{
    grid-template-columns:1fr;
}

.grid-3,
.grid-2{
    grid-template-columns:1fr;
}

.mini-stats{
    flex-wrap:wrap;
}

}

</style>

{% endblock %}
