    grid-template-columns:1fr 1fr;
    gap:40px;
    align-items:center;
}

.tags{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    margin-top:10px;
}

.tags span{
    padding:6px 10px;
    background:#ffffff10;
    border-radius:999px;
    font-size:12px;
}

/* TRUST */
.trust{
