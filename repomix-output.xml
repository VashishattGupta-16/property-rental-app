<!-- JavaScript to toggle Dropdowns (Mobile menu & Profile menu) -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const dropdownBtns = document.querySelectorAll('.js-dropdown-btn');

        function closeAllDropdowns() {
            document.querySelectorAll('.js-dropdown-menu').forEach(menu => {
                menu.classList.remove('show-dropdown');
            });
            dropdownBtns.forEach(btn => btn.setAttribute('aria-expanded', 'false'));
        }

        dropdownBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation(); // Stop click from hitting the document

                // Close all other open dropdowns first
                dropdownBtns.forEach(otherBtn => {
                    if (otherBtn === btn) return;
                    const otherMenu = otherBtn.nextElementSibling;
                    if (otherMenu) otherMenu.classList.remove('show-dropdown');
                    otherBtn.setAttribute('aria-expanded', 'false');
                });

                // Toggle the menu right next to this button
                const menu = btn.nextElementSibling;
                if (menu) {
                    menu.classList.toggle('show-dropdown');
                    btn.setAttribute('aria-expanded', menu.classList.contains('show-dropdown') ? 'true' : 'false');
                }
            });
        });

        // Close dropdowns if clicking anywhere outside
        document.addEventListener('click', (e) => {
            if (e.target.closest('.dropdown-container')) return;
            closeAllDropdowns();
        });

        // Close on Escape for accessibility
        document.addEventListener('keydown', (e) => {
            if (e.key !== 'Escape') return;
            closeAllDropdowns();
        });

        // Mobile accordion inside the menu
        document.querySelectorAll('.accordion-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                const accordion = btn.closest('.accordion');
                const content = accordion?.querySelector('.accordion-content');
                if (!content) return;

                const isOpen = btn.getAttribute('aria-expanded') === 'true';
                btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
                content.toggleAttribute('hidden', isOpen);
            });
        });
    });
</script>
</file>

