                        <textarea name="message" rows="4" required
                            class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:border-sky-500 outline-none transition-all">I am interested in "{{ rental.title }}". Please share more details.</textarea>

                    </div>

                    <button type="submit"
                        class="w-full py-5 bg-sky-600 hover:bg-sky-500 text-white font-black rounded-2xl transition-all shadow-xl shadow-sky-600/20 active:scale-95">

                        CONFIRM INQUIRY

                    </button>

                </form>

                {% endif %}

            </div>

        </div>
    </div>
</div>

<style>
