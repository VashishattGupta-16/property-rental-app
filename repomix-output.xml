                <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-house text-blue-500"></i> Primary Information
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Manually render first few fields or use a loop with if -->
                    <div class="flex flex-col gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.title.label }}</label>
                        <div class="{% if form.title.errors %}input-error{% endif %} contents">{{ form.title }}</div>
                        {% if form.title.errors %}
                            <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight">{{ form.title.errors.0 }}</p>
                        {% endif %}
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.location.label }}</label>
                        <div class="{% if form.location.errors %}input-error{% endif %} contents">{{ form.location }}</div>
                        {% if form.location.errors %}
                            <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight">{{ form.location.errors.0 }}</p>
                        {% endif %}
                    </div>
                    <div class="flex flex-col md:col-span-2 gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.description.label }}</label>
                        <div class="{% if form.description.errors %}input-error{% endif %} contents">{{ form.description }}</div>
                        {% if form.description.errors %}
                            <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight">{{ form.description.errors.0 }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 2: PRICING & TYPE -->
        <div class="step-content" id="step2">
            <div class="glass-card rounded-3xl p-8">
                <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-tag text-blue-500"></i> Pricing & Specifications
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.price.label }}</label>
                        <div class="{% if form.price.errors %}input-error{% endif %} contents">{{ form.price }}</div>
                        {% if form.price.errors %}
                            <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight">{{ form.price.errors.0 }}</p>
                        {% endif %}
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ form.property_type.label }}</label>
                        <div class="{% if form.property_type.errors %}input-error{% endif %} contents">{{ form.property_type }}</div>
                        {% if form.property_type.errors %}
                            <p class="text-red-400 text-[10px] font-bold uppercase tracking-tight">{{ form.property_type.errors.0 }}</p>
                        {% endif %}
                    </div>
                    <!-- Catch-all for remaining fields in the main form -->
                    {% for field in form %}
                        {% if field.name not in "title location description price property_type" %}
                            <div class="flex flex-col gap-1">
                                <label class="text-gray-400 text-xs font-bold uppercase mb-2">{{ field.label }}</label>
                                <div class="{% if field.errors %}input-error{% endif %} contents">{{ field }}</div>
                                {% if field.errors %}<p class="text-red-400 text-[10px] font-bold uppercase tracking-tight">{{ field.errors.0 }}</p>{% endif %}
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- STEP 3: GALLERY -->
        <div class="step-content" id="step3">
            <div class="glass-card rounded-3xl p-8">
                <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-images text-blue-500"></i> Visual Media
                </h2>
                <p class="text-gray-500 text-sm mb-6 italic">Upload up to 3 gallery images to make your listing stand out.</p>
                <div class="grid grid-cols-1 gap-4">
                    {% for form_img in formset %}
                        <div class="p-4 border border-white/5 rounded-2xl bg-white/5 royal-input">
                            {% for hidden in form_img.hidden_fields %}{{ hidden }}{% endfor %}
                            <div class="flex flex-col gap-1">
                                {{ form_img.image }}
                                {% if form_img.image.errors %}<p class="text-red-400 text-[10px] font-bold uppercase tracking-tight">{{ form_img.image.errors.0 }}</p>{% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- NAVIGATION BUTTONS -->
        <div class="flex justify-between items-center pt-8">
            <button type="button" id="prevBtn" class="hidden px-8 py-3 rounded-xl border border-white/10 text-white font-bold hover:bg-white/5 transition-all">
                Previous
            </button>
            <div class="ml-auto flex gap-4">
                <button type="button" id="nextBtn" class="px-10 py-4 bg-blue-600 text-white font-black rounded-xl shadow-lg shadow-blue-600/20 hover:bg-blue-500 transition-all">
                    Next Step
                </button>
                <button type="submit" id="submitBtn" class="hidden px-10 py-4 bg-emerald-600 text-white font-black rounded-xl shadow-lg shadow-emerald-600/20 hover:bg-emerald-500 transition-all">
                    {% if form.instance.pk %}Update Listing{% else %}Publish Listing{% endif %}
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    const steps = Array.from(document.querySelectorAll('.step-content'));
    const indicators = document.querySelectorAll('.step-indicator');
    const form = document.getElementById('multiStepForm');
    const progressLine = document.getElementById('progress-line');
    const nextBtn = document.getElementById('nextBtn');
    const prevBtn = document.getElementById('prevBtn');
    const submitBtn = document.getElementById('submitBtn');
    let currentStep = 0;

    function updateStep() {
        steps.forEach((step, index) => {
            step.classList.toggle('active', index === currentStep);
        });

        indicators.forEach((ind, index) => {
            ind.classList.toggle('active', index === currentStep);
            ind.classList.toggle('completed', index < currentStep);
        });

        progressLine.style.width = (currentStep / (steps.length - 1)) * 100 + "%";

        // Button Visibility
        prevBtn.classList.toggle('hidden', currentStep === 0);
        
        if (currentStep === steps.length - 1) {
            nextBtn.classList.add('hidden');
            submitBtn.classList.remove('hidden');
        } else {
            nextBtn.classList.remove('hidden');
            submitBtn.classList.add('hidden');
        }
    }

    nextBtn.addEventListener('click', () => {
        if (currentStep < steps.length - 1) {
            currentStep++;
            updateStep();
        }
    });

    prevBtn.addEventListener('click', () => {
        if (currentStep > 0) {
            currentStep--;
            updateStep();
        }
    });

    // Server-side error handling: find the first field with a Django error and jump to that step
    window.addEventListener('load', () => {
        const firstServerSideError = document.querySelector('.input-error');
        if (firstServerSideError) {
            const targetStep = firstServerSideError.closest('.step-content');
            if (targetStep) {
                currentStep = steps.indexOf(targetStep);
                updateStep();
            }
        }
    });
</script>
{% endblock %}
</file>

<file path="tweet/templates/wishlist.html">
{% extends base_template|default:"layout.html" %}
{% load static %}
{% load media_urls %}

{% block content %}

<div class="min-h-screen py-16 px-4">
    <div class="max-w-6xl mx-auto">

        <h1 class="text-3xl font-black text-white mb-8">
            Your Wishlist
        </h1>

        {% if wishlist %}

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

            {% for item in wishlist %}

            <!-- Wishlist Card -->
            <div id="wishlist-item-{{ item.id }}"
                 class="glass-card rounded-2xl overflow-hidden border border-white/10 hover:border-sky-500/40 transition-all duration-300 hover:-translate-y-1">

                <!-- IMAGE -->
                <a href="{% url 'rental_detail' item.rental.slug %}" class="block">
                    <div class="relative h-44 overflow-hidden">

                        {% if item.rental.image %}
                            <img
                                src="{{ item.rental.image|optimized_cloudinary_url:'f_auto,q_auto,c_fill,w_600,h_400' }}"
                                class="w-full h-full object-cover transition-transform duration-700 hover:scale-110"
                                loading="lazy"
                                decoding="async"
                                sizes="(min-width: 1280px) 25vw, (min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                                alt="{{ item.rental.title }}"
                            >
                        {% else %}
                            <div class="w-full h-full bg-slate-800 flex items-center justify-center text-slate-500 text-sm">
                                No Image
                            </div>
                        {% endif %}

                    </div>
                </a>

                <!-- CONTENT -->
                <div class="p-4">

                    <h3 class="text-base font-bold text-white truncate">
                        {{ item.rental.title }}
                    </h3>

                    <p class="text-slate-400 text-xs flex items-center gap-1.5 mb-3 truncate">
                        <i class="fa-solid fa-location-dot text-blue-500 text-[9px]"></i>
                        {{ item.rental.location }}
                    </p>

                    <div class="flex justify-between items-center border-t border-white/5 pt-3">

                        <span class="text-lg font-black text-white">
                            ₹{{ item.rental.price }}
                        </span>

                        <a href="{% url 'rental_detail' item.rental.slug %}"
                           class="text-xs font-black text-white hover:text-sky-400">
                            View →
                        </a>

                    </div>

                    <!-- HTMX REMOVE BUTTON -->
                    <form
                        hx-post="{% url 'toggle_wishlist' item.rental.id %}"
                        hx-target="#wishlist-item-{{ item.id }}"
                        hx-swap="outerHTML"
                        hx-on::after-request="if (event.detail.xhr.status === 204) this.closest('#wishlist-item-{{ item.id }}')?.remove()"
                        class="mt-3"
                    >
                        {% csrf_token %}

                        <button type="submit"
                                class="text-xs font-bold text-red-400 hover:text-red-300 transition">
                            Remove from wishlist ✕
                        </button>
                    </form>

                </div>
            </div>

            {% endfor %}

        </div>

        {% if page_obj.has_other_pages %}
        <nav class="mt-10 flex items-center justify-center gap-3" aria-label="Wishlist pagination">
            {% if page_obj.has_previous %}
            <a href="?page={{ page_obj.previous_page_number }}"
               class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm font-bold text-white hover:bg-white/10 transition">
                Previous
            </a>
            {% endif %}

            <span class="px-4 py-2 text-sm text-slate-400">
                Page {{ page_obj.number }} of {{ page_obj.paginator.num_pages }}
            </span>

            {% if page_obj.has_next %}
            <a href="?page={{ page_obj.next_page_number }}"
               class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm font-bold text-white hover:bg-white/10 transition">
                Next
            </a>
            {% endif %}
        </nav>
        {% endif %}

        {% else %}

        <!-- EMPTY STATE -->
        <div class="text-center py-20 glass-card rounded-2xl border border-white/10">
            <p class="text-slate-400">
                Your wishlist is empty.
            </p>

            <a href="{% url 'rental_list' %}"
               class="mt-4 inline-block px-6 py-2 rounded-xl bg-blue-600 hover:bg-blue-500 transition-all text-white font-bold">
                Explore Listings
            </a>
        </div>

        {% endif %}

    </div>
</div>

{% endblock %}
