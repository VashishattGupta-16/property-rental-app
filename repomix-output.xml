        }

        .master-background {
            position: fixed;
            inset: 0;
            z-index: -1;
            background-image: linear-gradient(rgba(2, 6, 23, 0.82), rgba(2, 6, 23, 0.88)),
                url('https://i.pinimg.com/736x/bc/fd/7e/bcfd7e31ee8f647b40d7f5038a1f17e2.jpg');
            background-size: cover;
            background-position: center;
