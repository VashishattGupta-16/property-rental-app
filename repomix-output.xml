}

.section-head h2{
    font-size:2rem;
}

/* GRIDS */
.grid-3{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
}

.grid-2{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:20px;
}

/* CARDS */
.card{
    background:#ffffff08;
    border:1px solid #ffffff10;
