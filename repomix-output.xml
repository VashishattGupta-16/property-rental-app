                        <i class="fa-solid fa-paper-plane"></i>
                    </div>

                    <h3 class="text-2xl font-black text-white mb-2">
                        Request Sent!
                    </h3>

                    <p class="text-slate-400">
                        The owner has been notified of your interest.
                    </p>

                    <a href="{% url 'index' %}"
                        class="mt-8 inline-block px-10 py-4 bg-sky-600 hover:bg-sky-500 text-white font-black rounded-xl transition-all">

