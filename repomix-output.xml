                if (splash) {
                    setTimeout(() => splash.remove(), 650);
                }
            }

            // Ensure splash screen is hidden on DOMContentLoaded and pageshow (for BFCache)
            function initSplashAndAppReady() {
                document.body.classList.add('app-ready'); // Ensure body is visible
