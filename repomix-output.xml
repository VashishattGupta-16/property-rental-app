<file path="tweet/templates/profile.html">
{% extends base_template %}
{% load static %}
{% load media_urls %}

{% block content %}

<div class="min-h-screen py-16 px-4 relative">

    <!-- Glow background -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-sky-500/10 blur-[120px] rounded-full -z-10"></div>

    <div class="max-w-6xl mx-auto grid lg:grid-cols-3 gap-8">

        <!-- LEFT: USER CARD -->
        <div class="glass-card p-8 rounded-[2.5rem] border border-white/10">

            <div class="flex flex-col items-center text-center">

                <!-- Avatar -->
                <div class="w-24 h-24 rounded-2xl bg-sky-500/20 flex items-center justify-center text-3xl font-black text-white border border-white/10 mb-4">
                    {{ user.email|slice:":1"|upper }}
                </div>

                <h2 class="text-2xl font-black text-white">
                    {{ user.first_name }} {{ user.last_name }}
                </h2>

                <p class="text-slate-400 text-sm">{{ user.email }}</p>

                {% if user.phone_number %}
                <p class="text-slate-500 text-xs mt-1">{{ user.phone_number }}</p>
                {% endif %}

                <div class="mt-6 w-full grid grid-cols-2 gap-4">

                    <div class="bg-white/5 border border-white/10 rounded-2xl p-4 text-center">
                        <p class="text-xs text-slate-500 font-bold uppercase">Listings</p>
                        <p class="text-2xl font-black text-sky-400">{{ listings_count }}</p>
                    </div>

                    <div class="bg-white/5 border border-white/10 rounded-2xl p-4 text-center">
                        <p class="text-xs text-slate-500 font-bold uppercase">Wishlist</p>
                        <p class="text-2xl font-black text-sky-400">{{ wishlist_count }}</p>
                    </div>

                </div>

            </div>

        </div>

        <!-- MIDDLE: LISTINGS -->
        <div class="lg:col-span-2 glass-card p-8 rounded-[2.5rem] border border-white/10">

            <h3 class="text-xl font-black text-white mb-6">Your Listings</h3>

            {% if listings %}
                <div class="grid sm:grid-cols-2 gap-4">

                    {% for rental in listings %}
                    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-sky-500/40 transition">

                        <img src="{{ rental.image|optimized_cloudinary_url:'f_auto,q_auto,c_fill,w_600,h_400' }}"
                             loading="lazy"
                             decoding="async"
                             sizes="(min-width: 1024px) 24rem, 100vw"
                             alt="{{ rental.title }}"
                             class="h-32 w-full object-cover">

                        <div class="p-4">
                            <p class="text-white font-bold truncate">{{ rental.title }}</p>
                            <p class="text-slate-400 text-xs">{{ rental.location }}</p>

                            <div class="flex justify-between items-center mt-3">
                                <span class="text-sky-400 font-black">₹{{ rental.price }}</span>

                                <a href="{% url 'rental_detail' rental.slug %}"
                                   class="text-xs font-black text-white hover:text-sky-400">
                                    View →
                                </a>
                            </div>
                        </div>

                    </div>
                    {% endfor %}

                </div>
                {% if page_obj.has_other_pages %}
                <nav class="mt-6 flex items-center justify-center gap-3" aria-label="Profile listings pagination">
                    {% if page_obj.has_previous %}
                    <a href="?page={{ page_obj.previous_page_number }}"
                       class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-xs font-bold text-white hover:bg-white/10 transition">
                        Previous
                    </a>
                    {% endif %}

                    <span class="px-3 py-2 text-xs text-slate-400">
                        Page {{ page_obj.number }} of {{ page_obj.paginator.num_pages }}
                    </span>

                    {% if page_obj.has_next %}
                    <a href="?page={{ page_obj.next_page_number }}"
                       class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-xs font-bold text-white hover:bg-white/10 transition">
                        Next
                    </a>
                    {% endif %}
                </nav>
                {% endif %}
            {% else %}
                <p class="text-slate-500">No listings yet.</p>
            {% endif %}

        </div>

    </div>

</div>

<style>
.glass-card {
    background: rgba(15, 23, 42, 0.65);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
}
</style>

{% endblock %}
</file>

<file path="tweet/templates/room_describe.html">
{% extends base_template|default:"layout.html" %}
{% load media_urls %}

{% block content %}

<style>
    .image-scroller {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        gap: 1.5rem;
        padding-bottom: 1rem;
    }

    .image-scroller::-webkit-scrollbar {
        display: none;
    }

    .scroller-item {
        flex: 0 0 85%;
        scroll-snap-align: center;
        aspect-ratio: 16/10;
        border-radius: 2.5rem;
        overflow: hidden;
    }

    @media (min-width: 1024px) {
        .scroller-item {
            flex: 0 0 60%;
        }
    }
</style>

<div class="mx-auto max-w-[1400px] fluid-page fluid-section">

    <!-- HEADER -->
    <div class="flex flex-col lg:flex-row justify-between items-start gap-8 mb-12">

        <div class="space-y-4">

            <span class="inline-flex items-center gap-2 bg-[var(--accent)] text-white text-[9px] font-black px-4 py-1 rounded-full uppercase tracking-widest">
                <i class="fa-solid fa-tag"></i>
                {{ rental.get_property_type_display }}
            </span>

            <h1 class="text-4xl lg:text-6xl font-black leading-tight safe-wrap">
                <i class="fa-solid fa-house-chimney mr-2 text-[var(--accent)]"></i>
                {{ rental.title|default:"Untitled Property" }}
            </h1>

            <p class="text-lg font-bold text-[var(--text-muted)] flex items-center gap-2">
                <i class="fa-solid fa-location-dot text-[var(--accent)]"></i>
                {{ rental.location|default:"Unknown Location" }}
            </p>

        </div>

        <!-- PRICE CARD -->
        <div class="glass-card p-8 w-full sm:w-auto sm:min-w-[280px] text-right shadow-2xl">

            <p class="text-[10px] font-black uppercase tracking-widest opacity-40">
                <i class="fa-solid fa-indian-rupee-sign"></i> Monthly Rent
            </p>

            <h2 class="text-4xl font-black">
                ₹{{ rental.price|default:"0" }}
            </h2>

            <p class="text-[10px] font-bold opacity-30">/ Month</p>

        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- LEFT -->
        <div class="lg:col-span-8 space-y-8">

            <!-- IMAGES -->
            <div class="image-scroller">

                <div class="scroller-item border">
                    {% if rental.image %}
                        <img src="{{ rental.image|optimized_cloudinary_url:'f_auto,q_auto,c_limit,w_1200' }}"
                              class="media-cover"
                              fetchpriority="high"
                              decoding="async"
                              sizes="(min-width: 1024px) 56vw, 92vw"
                              alt="{{ rental.title }}">
                    {% else %}
                        <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                            No Image
                        </div>
                    {% endif %}
                </div>

                {% for item in rental.gallery.all %}
                <div class="scroller-item border">
                    {% if item.image %}
                        <img src="{{ item.image|optimized_cloudinary_url:'f_auto,q_auto,c_fill,w_900,h_560' }}"
                              class="media-cover"
                              loading="lazy"
                              decoding="async"
                              sizes="(min-width: 1024px) 56vw, 92vw"
                              alt="Gallery image">
                    {% else %}
                        <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                            No Image
                        </div>
                    {% endif %}
                </div>
                {% endfor %}

            </div>

            <!-- DESCRIPTION -->
            <div class="glass-card p-10">
                <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)] mb-6">
                    Overview
                </h3>

                <div class="text-lg opacity-80">
                    {{ rental.description|linebreaks|default:"No description available." }}
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-4 space-y-6">

            <!-- SPECIFICATIONS -->
            <div class="glass-card p-8">
                <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)] mb-6">
                    Specifications
                </h3>

                <div class="grid grid-cols-2 gap-4">

                    <div class="border rounded-xl p-4 text-center">
                        <i class="fa-solid fa-house text-2xl mb-2"></i>
                        <p class="text-xs font-bold">{{ rental.get_property_type_display }}</p>
                        <p class="text-[10px] opacity-50">Type</p>
                    </div>

                    <div class="border rounded-xl p-4 text-center">
                        <i class="fa-solid fa-couch text-2xl mb-2"></i>
                        <p class="text-xs font-bold">{{ rental.get_furnishing_display }}</p>
                        <p class="text-[10px] opacity-50">Furnishing</p>
                    </div>

                    <div class="border rounded-xl p-4 text-center">
                        <i class="fa-solid fa-bed text-2xl mb-2"></i>
                        <p class="text-xs font-bold">{{ rental.bedrooms|default:"--" }}</p>
                        <p class="text-[10px] opacity-50">Bedrooms</p>
                    </div>

                    <div class="border rounded-xl p-4 text-center">
                        <i class="fa-solid fa-bath text-2xl mb-2"></i>
                        <p class="text-xs font-bold">{{ rental.bathrooms|default:"--" }}</p>
                        <p class="text-[10px] opacity-50">Bathrooms</p>
                    </div>

                </div>
            </div>

            <!-- OWNER -->
            <div class="glass-card p-8 flex items-center gap-5">

                <div class="w-14 h-14 rounded-xl bg-black text-white flex items-center justify-center font-black">
                    <i class="fa-solid fa-user"></i>
                </div>

                <div>
                    <p class="text-[9px] uppercase opacity-40">Listed by</p>
                    <p class="text-xl font-black">
                        {{ rental.user.first_name|default:rental.user.email }}
                    </p>
                    <p class="text-xs opacity-60">
                        {{ rental.user.email }}
                    </p>
                </div>

            </div>

            <!-- SHARE SECTION (FIXED & IMPROVED) -->
            <div class="glass-card p-8 space-y-4">

                <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)]">
                    Share Property
                </h3>

                <!-- Copy Link -->
                <div class="flex gap-2">
                    <input type="text"
                           id="shareLink"
                           value="{{ request.build_absolute_uri }}"
                           readonly
                           class="w-full p-3 text-xs rounded-lg border bg-transparent">

                    <button onclick="copyLink()"
                            class="px-4 py-2 text-xs font-black bg-black text-white rounded-lg">
                        Copy
                    </button>
                </div>

                <!-- Social Buttons -->
                <div class="flex flex-wrap gap-2 text-xs font-bold">

                    <a class="px-3 py-2 rounded-lg bg-green-500 text-white"
                       href="https://wa.me/?text={{ request.build_absolute_uri }}"
                       target="_blank">
                        WhatsApp
                    </a>

                    <a class="px-3 py-2 rounded-lg bg-blue-600 text-white"
                       href="https://www.facebook.com/sharer/sharer.php?u={{ request.build_absolute_uri }}"
                       target="_blank">
                        Facebook
                    </a>

                    <a class="px-3 py-2 rounded-lg bg-black text-white"
                       href="https://twitter.com/intent/tweet?url={{ request.build_absolute_uri }}&text={{ rental.title }}"
                       target="_blank">
                        X
                    </a>

                </div>
            </div>

            <!-- CONTACT -->
            <div class="glass-card p-8 space-y-4">

                <h4 class="text-[10px] font-black text-[var(--accent)] uppercase">
                    Full Address
                </h4>

                <p class="text-sm font-bold opacity-70">
                    {{ rental.address|default:rental.location }}
                </p>

                <a href="{% url 'rental_contact' rental.id %}"
