<body class="text-slate-200" hx-boost="true" hx-ext="view-transitions" hx-target="#main-content" hx-select="#main-content"
    hx-swap="outerHTML transition:true">

    <div class="master-background"></div>

    {% if not is_htmx_partial %}
    {% include "nav.html" %}
    {% endif %}

   

    <!-- Django Messages -->
    {% if messages %}
    <div style="position: fixed; top: 80px; right: 20px; z-index: 1000; max-width: 300px;">
        {% for message in messages %}
        <div class="p-4 mb-4 text-sm rounded-lg shadow-lg
            {% if message.tags == 'success' %} bg-green-100 text-green-800 border border-green-200 {% endif %}
            {% if message.tags == 'info' %} bg-blue-100 text-blue-800 border border-blue-200 {% endif %}
            {% if message.tags == 'warning' %} bg-yellow-100 text-yellow-800 border border-yellow-200 {% endif %}
            {% if message.tags == 'error' %} bg-red-100 text-red-800 border border-red-200 {% endif %}" role="alert">
            <span class="font-medium">{{ message }}</span>
        </div>
        {% endfor %}
    </div>

    <script>
        setTimeout(() => {
            document.querySelectorAll('[role="alert"]').forEach(el => el.remove());
        }, 5000);
    </script>
    {% endif %}

    <main id="main-content">
        {% if request.path != '/' %}
        <div class="fluid-page pt-6 mb-2">
            <button onclick="history.back()"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl glass-card text-[10px] font-black uppercase tracking-widest text-slate-300 hover:text-white hover:border-sky-500/50 transition-all active:scale-95 shadow-lg">
                <i class="fa-solid fa-arrow-left text-sky-500"></i>
                Back
            </button>
        </div>
        {% endif %}

        {% block content %}{% endblock %}
    </main>

    {% if not is_htmx_partial %}
    {% include "footer.html" %}
    {% endif %}

    <script>
        (function() {
            // 1. Initial Load Animation
            window.addEventListener('load', () => {
                document.body.classList.add('app-ready');
            });

            // 2. Rapid Click Debouncing
            let isNavigating = false;
            document.body.addEventListener('htmx:beforeRequest', (e) => {
                if (isNavigating && e.detail.requestConfig.trigger?.tagName === 'A') {
                    e.preventDefault();
                    return;
                }
                isNavigating = true;
            });

            // 3. Fallback Transition Management (For older browsers)
            document.body.addEventListener('htmx:beforeSwap', (e) => {
                // Add class to trigger CSS exit animation
                document.body.classList.add('htmx-swapping');
            });

            document.body.addEventListener('htmx:afterSettle', () => {
                // Remove class to trigger CSS entry animation
                document.body.classList.remove('htmx-swapping');
                isNavigating = false;
            });

            // 4. Smooth scroll to top on page change
            document.body.addEventListener('htmx:afterSwap', (e) => {
                if (e.detail.target.id === 'main-content') {
                    window.scrollTo({ top: 0, behavior: 'instant' });
                }
            });
        })();
    </script>

    <!-- Wishlist Script -->
    <script>
        (function () {
            function getCookie(name) {
                const cookieValue = document.cookie
                    .split(";")
                    .map(v => v.trim())
                    .find(v => v.startsWith(name + "="));
                return cookieValue ? decodeURIComponent(cookieValue.split("=")[1]) : null;
            }

            function setWishlisted(form, wishlisted) {
                const button = form.querySelector("button");
                const icon = form.querySelector("i");
                const badge = form.closest("[data-rental-card]")?.querySelector("[data-wishlist-badge]");

                if (button) {
                    button.setAttribute("aria-pressed", wishlisted);
                    button.setAttribute("aria-label", wishlisted ? "Remove from wishlist" : "Add to wishlist");
                    button.dataset.wishlisted = wishlisted ? "1" : "0";
                }

                if (icon) {
                    icon.classList.toggle("fa-solid", wishlisted);
                    icon.classList.toggle("fa-regular", !wishlisted);
                    icon.classList.toggle("text-red-500", wishlisted);
                }

                if (badge) {
                    badge.classList.toggle("opacity-0", !wishlisted);
                    badge.classList.toggle("opacity-100", wishlisted);
                }
            }

            async function onWishlistSubmit(e) {
                const form = e.target;
                if (!(form instanceof HTMLFormElement)) return;
                if (!form.classList.contains("js-wishlist-form")) return;

                e.preventDefault();

                const button = form.querySelector("button");
                if (button) button.disabled = true;

                try {
                    const csrfToken = getCookie("csrftoken");

                    const headers = {
                        "X-Requested-With": "XMLHttpRequest",
                        "Accept": "application/json",
                        ...(csrfToken && { "X-CSRFToken": csrfToken })
                    };

                    const resp = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form),
                        credentials: "same-origin",
                        headers,
                    });

                    if (resp.status === 401) {
                        const data = await resp.json().catch(() => null);
                        const loginUrl = data?.login_url || "{% url 'account_login' %}";
                        window.location.href = `${loginUrl}?next=${encodeURIComponent(window.location.href)}`;
                        return;
                    }

                    const data = await resp.json().catch(() => null);
                    if (!data?.ok) return;

                    setWishlisted(form, !!data.wishlisted);

                    if (!data.wishlisted && form.dataset.removeOnUnwish === "1") {
                        form.closest("[data-rental-card]")?.remove();
                    }

                } catch (err) {
                    form.submit();
                } finally {
                    if (button) button.disabled = false;
                }
            }

            document.addEventListener("submit", onWishlistSubmit, true);
        })();
    </script>

    <!-- Service Worker -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register("{% url 'service_worker' %}", { scope: "/" })
                    .then(reg => console.log("ServiceWorker registered:", reg.scope))
                    .catch(err => console.error("ServiceWorker failed:", err));
            });
        }
    </script>

    <div id="page-scripts">
        {% block extra_scripts %}{% endblock %}
    </div>

</body>

</html>
</file>

