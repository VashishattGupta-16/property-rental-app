                                    class="text-[8px] font-black text-slate-500 uppercase tracking-widest group-hover:text-white/70">
                                    Instant WhatsApp
                                </p>

                                <p class="text-white font-bold text-sm">
                                    Chat with Owner
                                </p>
                            </div>

                        </a>
                        {% endif %}

                    </div>

                </div>

                {% endif %}
