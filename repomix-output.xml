:root {
  --nav-bg: rgba(2, 6, 23, 0.72);
  --nav-border: rgba(255, 255, 255, 0.08);
  --nav-surface: rgba(255, 255, 255, 0.06);
  --nav-surface-hover: rgba(255, 255, 255, 0.1);
  --nav-text: #e2e8f0;
  --nav-muted: rgba(226, 232, 240, 0.75);
  --nav-accent: #38bdf8;
  --nav-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
}

.navbar-wrapper {
  position: sticky;
  top: 0;
  z-index: 50;
  background: var(--nav-bg);
  border-bottom: 1px solid var(--nav-border);
  backdrop-filter: blur(18px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
}

.navbar-shell {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0.85rem 1rem;
}

.navbar-grid {
  display: grid;
  /* Keep the brand truly centered on small screens */
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 1rem;
}

.navbar-left,
.navbar-center,
.navbar-right {
  display: flex;
  align-items: center;
  gap: 0.85rem;
}

.navbar-left {
  justify-content: flex-start;
}

.navbar-right {
  justify-content: flex-end;
}

.navbar-center {
  justify-content: center;
}

.logo-wrap {
  text-decoration: none;
  color: var(--nav-text);
}

.logo-text {
  margin: 0;
  font-weight: 900;
  letter-spacing: -0.02em;
  font-size: 1.1rem;
}

.logo-highlight {
  color: var(--nav-accent);
}

.nav-link,
.login-link {
  text-decoration: none;
  color: var(--nav-muted);
  font-weight: 700;
  font-size: 0.95rem;
  padding: 0.5rem 0.65rem;
  border-radius: 0.75rem;
  transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
}

.nav-link:hover,
.login-link:hover {
  color: var(--nav-text);
  background: var(--nav-surface);
}

.join-btn {
  text-decoration: none;
  color: #0b1220;
  background: var(--nav-accent);
  font-weight: 900;
  font-size: 0.95rem;
  padding: 0.6rem 0.9rem;
  border-radius: 1rem;
  box-shadow: 0 10px 24px rgba(56, 189, 248, 0.18);
  transition: transform 0.15s ease, filter 0.15s ease;
}

.join-btn:hover {
  filter: brightness(1.05);
  transform: translateY(-1px);
}

.dropdown-container {
  position: relative;
}

.dropdown-trigger {
  appearance: none;
  border: 1px solid var(--nav-border);
  background: var(--nav-surface);
  color: var(--nav-text);
  border-radius: 1rem;
  padding: 0.55rem 0.75rem;
  font-weight: 800;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: background 0.15s ease, transform 0.15s ease, border-color 0.15s ease;
}

.dropdown-trigger:hover {
  background: var(--nav-surface-hover);
  border-color: rgba(56, 189, 248, 0.35);
}

.profile-trigger {
  appearance: none;
  border: 0;
  padding: 0;
  background: transparent;
  cursor: pointer;
}

.profile-trigger:focus-visible {
  outline: 2px solid rgba(56, 189, 248, 0.6);
  outline-offset: 4px;
  border-radius: 999px;
}

.dropdown-arrow {
  font-size: 0.85em;
  opacity: 0.9;
}

.dropdown-menu {
  position: absolute;
  top: calc(100% + 0.65rem);
  left: 0;
  min-width: 14rem;
  max-width: calc(100vw - 2rem);
  display: none;
  z-index: 60;
}

/* JS toggles this class for clicks */
.dropdown-menu.show-dropdown {
  display: block;
}

.dropdown-card {
  background: rgba(2, 6, 23, 0.92);
  border: 1px solid var(--nav-border);
  border-radius: 1.25rem;
  padding: 0.5rem;
  box-shadow: var(--nav-shadow);
  backdrop-filter: blur(22px);
}

.dropdown-sep {
  border: 0;
  border-top: 1px solid var(--nav-border);
  margin: 0.5rem 0;
}

.dropdown-item {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  width: 100%;
  padding: 0.7rem 0.85rem;
  border-radius: 1rem;
  text-decoration: none;
  color: var(--nav-text);
  font-weight: 800;
  font-size: 0.95rem;
  background: transparent;
  border: 0;
  cursor: pointer;
  transition: background 0.15s ease, transform 0.15s ease;
}

.dropdown-item:hover {
  background: rgba(56, 189, 248, 0.12);
  transform: translateX(2px);
}

.logout-btn {
  text-align: left;
}

.profile-avatar {
  width: 2.3rem;
  height: 2.3rem;
  border-radius: 999px;
  display: grid;
  place-items: center;
  color: #0b1220;
  background: linear-gradient(135deg, #38bdf8, #2563eb);
  font-weight: 900;
  box-shadow: 0 14px 30px rgba(37, 99, 235, 0.18);
}

/* Mobile/desktop behavior */
.mobile-dropdown {
  display: inline-flex;
}

.navbar-center {
  display: flex;
  justify-content: center;
  min-width: 0;
}

.navbar-links {
  display: none;
  align-items: center;
  gap: 0.85rem;
}

/* Mobile dropdown sizing */
.mobile-dropdown .dropdown-menu {
  width: min(92vw, 22rem);
}

.mobile-dropdown .dropdown-card {
  max-height: calc(100vh - 110px);
  overflow: auto;
  overscroll-behavior: contain;
}

/* Accordion (mobile menu) */
.accordion-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  padding: 0.7rem 0.85rem;
  border-radius: 1rem;
  border: 0;
  background: transparent;
  color: var(--nav-text);
  font-weight: 900;
  font-size: 0.95rem;
  cursor: pointer;
  transition: background 0.15s ease, transform 0.15s ease;
}

.accordion-btn:hover {
  background: rgba(56, 189, 248, 0.10);
}

.accordion-btn i {
  transition: transform 0.18s ease;
  opacity: 0.9;
}

.accordion-btn[aria-expanded="true"] i {
  transform: rotate(180deg);
}

.accordion-content {
  padding: 0.25rem 0 0.15rem;
}

@media (min-width: 768px) {
  .navbar-grid {
    grid-template-columns: auto 1fr auto;
  }
  .mobile-dropdown {
    display: none;
  }
  .navbar-links {
    display: flex;
  }
  .dropdown-menu {
    left: 0;
  }

  /* Desktop dropdowns hover logic */
  .desktop-dropdown:hover .desktop-dropdown-menu,
  .desktop-dropdown:focus-within .desktop-dropdown-menu {
    display: block;
  }
}

/* Position profile dropdown to the right edge */
.profile-dropdown-menu {
  left: auto;
  right: 0;
}
