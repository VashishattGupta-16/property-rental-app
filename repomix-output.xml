<file path="tweet/templates/index.html">
{% extends base_template|default:"layout.html" %}

{% load static %}

{% block title %}Empire Estate | Premium Rentals{% endblock %}

{% block content %}

<style>
  .lp-aurora {
    background:
      radial-gradient(600px 280px at 12% 10%, rgba(59, 130, 246, .18), transparent 60%),
      radial-gradient(520px 260px at 78% 18%, rgba(168, 85, 247, .14), transparent 55%),
      radial-gradient(640px 320px at 55% 78%, rgba(34, 211, 238, .10), transparent 55%),
      radial-gradient(420px 260px at 16% 86%, rgba(14, 165, 233, .10), transparent 55%);
    filter: blur(18px);
    opacity: .95;
  }

  @keyframes lp-float-a {
    0% {
      transform: translate3d(0, 0, 0)
    }

    50% {
      transform: translate3d(0, -18px, 0)
    }

    100% {
      transform: translate3d(0, 0, 0)
    }
  }

  @keyframes lp-float-b {
    0% {
      transform: translate3d(0, 0, 0)
    }

    50% {
      transform: translate3d(0, 14px, 0)
    }

    100% {
      transform: translate3d(0, 0, 0)
    }
  }

  @keyframes lp-float-c {
    0% {
      transform: translate3d(0, 0, 0)
    }

    50% {
      transform: translate3d(10px, -10px, 0)
    }

    100% {
      transform: translate3d(0, 0, 0)
    }
  }

  .lp-float-a {
    animation: lp-float-a 10s ease-in-out infinite;
    will-change: transform;
  }

  .lp-float-b {
    animation: lp-float-b 12s ease-in-out infinite;
    will-change: transform;
  }

  .lp-float-c {
    animation: lp-float-c 14s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes lp-gradient {
    0% {
      background-position: 0% 50%
    }

    50% {
      background-position: 100% 50%
    }

    100% {
      background-position: 0% 50%
    }
  }

  .lp-gradient-text {
    background-image: linear-gradient(90deg, #60a5fa, #a78bfa, #22d3ee, #60a5fa);
    background-size: 300% 300%;
    animation: lp-gradient 10s ease infinite;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .reveal {
    opacity: 0;
    transform: translate3d(0, 18px, 0);
    filter: blur(8px);
    transition: opacity 700ms ease, transform 700ms ease, filter 700ms ease;
    will-change: transform, opacity, filter;
  }

  .reveal.is-inview {
    opacity: 1;
    transform: none;
    filter: none;
  }

  @media (prefers-reduced-motion: reduce) {

    .lp-float-a,
    .lp-float-b,
    .lp-float-c {
      animation: none !important;
    }

    .lp-gradient-text {
      animation: none !important;
    }

    .reveal {
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
    }
