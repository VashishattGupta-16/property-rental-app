        .btn-primary,
        .glass-card {
            transition: transform var(--ui-transition), box-shadow var(--ui-transition), background-color var(--ui-transition), border-color var(--ui-transition);
        }

        button:hover,
        input[type="submit"]:hover,
        .btn:hover,
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--ui-shadow-soft);
        }

        button:active,
        input[type="submit"]:active,
        .btn:active,
        .btn-primary:active {
            transform: translateY(0) scale(.98);
        }

        .skeleton {
            position: relative;
            overflow: hidden;
            background: rgba(255, 255, 255, .05);
            border-radius: 1rem;
            min-height: 1rem;
            color: transparent;
        }

        .skeleton::after {
            content: "";
            position: absolute;
            inset: 0;
            transform: translateX(-100%);
            background: linear-gradient(90deg, rgba(255, 255, 255, .04) 0%, rgba(255, 255, 255, .18) 50%, rgba(255, 255, 255, .04) 100%);
            animation: shimmer 1.6s ease-in-out infinite;
        }

        @keyframes shimmer {
            to {
                transform: translateX(100%);
            }
        }
    </style>
</head>

