<file path="tweet/templates/rental_contact.html">
{% extends base_template %}
{% load static %}
{% load media_urls %}

{% block content %}
<div class="relative min-h-screen py-20 px-4">

    <!-- BG BLUR -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-sky-500/10 rounded-full blur-[120px] -z-10"></div>

    <div class="max-w-6xl mx-auto">

        <!-- HEADER -->
        <div class="text-center mb-16">
            <h1 class="text-5xl md:text-7xl font-black text-white mb-4 tracking-tighter uppercase">
                Secure your <span class="text-sky-500">Space.</span>
            </h1>

            <p class="text-slate-400 font-medium text-lg">
                Direct inquiry to the property owner via Empire Estate.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

            <!-- LEFT -->
            <div class="space-y-6">

                {% if rental %}

                <!-- PROPERTY CARD -->
                <div class="glass-card p-6 rounded-[2rem] border border-white/10 relative overflow-hidden">

                    <img src="{{ rental.image|optimized_cloudinary_url:'f_auto,q_auto,c_fill,w_800,h_480' }}"
                        loading="lazy"
                        decoding="async"
                        sizes="(min-width: 1024px) 50vw, 100vw"
                        alt="{{ rental.title }}"
                        class="w-full h-48 object-cover rounded-2xl mb-6 shadow-2xl">

                    <h3 class="text-2xl font-bold text-white mb-2">
                        {{ rental.title }}
                    </h3>

                    <p class="text-sky-400 font-black text-xl mb-4">
                        ₹{{ rental.price }}
                        <span class="text-xs text-slate-500 uppercase tracking-widest">
                            / Month
                        </span>
                    </p>

                    <div class="flex items-center gap-2 text-slate-400 text-sm italic">
                        <i class="fa-solid fa-location-dot text-sky-500"></i>
                        {{ rental.location }}
                    </div>

                </div>

                <!-- OWNER DETAILS -->
                <div class="glass-card p-8 rounded-[2rem] border border-white/5 bg-sky-500/5 space-y-6">

                    <p class="text-[10px] font-black text-sky-500 uppercase tracking-[0.3em] mb-4 text-center italic">
                        Verified Owner Details
                    </p>

                    <div class="space-y-4">

                        <!-- EMAIL -->
                        <a href="mailto:{{ rental.user.email }}?subject=Inquiry regarding {{ rental.title }}"
                            class="flex items-center gap-4 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-sky-500/50 hover:bg-sky-500/10 transition-all group">

                            <div
                                class="w-10 h-10 rounded-xl bg-sky-500/20 flex items-center justify-center text-sky-500">
                                <i class="fa-solid fa-envelope-open-text"></i>
                            </div>

                            <div>
                                <p class="text-[8px] font-black text-slate-500 uppercase tracking-widest">
                                    Send Direct Email
                                </p>

                                <p
                                    class="text-white font-bold text-sm group-hover:text-sky-400 transition-colors break-all">
                                    {{ rental.user.email }}
                                </p>
                            </div>

                        </a>

                        <!-- OWNER -->
                        <div class="flex items-center gap-4 p-4">

                            <div
                                class="w-10 h-10 rounded-xl bg-sky-500/20 flex items-center justify-center text-sky-500">
                                <i class="fa-solid fa-user-tie"></i>
                            </div>

                            <div>
                                <p class="text-[8px] font-black text-slate-500 uppercase tracking-widest">
                                    Listing Agent
                                </p>

                                <p class="text-white font-bold text-sm">
                                    {{ rental.user.first_name }} {{ rental.user.last_name }}
                                </p>
                            </div>

                        </div>

                        <!-- WHATSAPP -->
                        {% if rental.contact %}
                        <a href="https://wa.me/{{ rental.contact|cut:'+'|cut:' ' }}?text=Hey%20I%20am%20interested%20in%20{{ rental.title }}"
