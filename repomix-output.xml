            <p class="text-[10px] font-black uppercase tracking-widest opacity-40">
                <i class="fa-solid fa-indian-rupee-sign"></i> Monthly Rent
            </p>

            <h2 class="text-4xl font-black">
                ₹{{ rental.price|default:"0" }}
            </h2>

            <p class="text-[10px] font-bold opacity-30">/ Month</p>

            <!-- Wishlist Button (Detail) -->
            <div class="mt-4 text-left">
                <button
                    id="wishlist-btn"
                    data-rental-id="{{ rental.id }}"
                    data-wishlisted="{{ is_wishlisted|yesno:'1,0' }}"
                    data-csrf="{{ csrf_token }}"
                    onclick="toggleWishlist(this)"
                    class="wishlist-btn inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-black/50 backdrop-blur-md border border-white/10 text-white hover:bg-red-500/80 transition-all duration-300 active:scale-95">
                    <i id="wishlist-icon" class="{{ is_wishlisted|yesno:'fa-solid fa-heart text-red-500,fa-regular fa-heart' }}"></i>
                    <span id="wishlist-label" class="text-sm font-bold">{{ is_wishlisted|yesno:'Saved,Save' }}</span>
                </button>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- LEFT -->
        <div class="lg:col-span-8 space-y-8">

            <!-- IMAGES -->
            <div class="image-scroller">

                <div class="scroller-item border">
                    {% if rental.image %}
                    <img src="{{ rental.image|optimized_cloudinary_url:'f_auto,q_auto,c_limit,w_1200' }}"
                        class="media-cover" fetchpriority="high" decoding="async" sizes="(min-width: 1024px) 56vw, 92vw"
                        alt="{{ rental.title }}">
                    {% else %}
                    <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                        No Image
                    </div>
                    {% endif %}
                </div>

                {% for item in rental.gallery.all %}
                <div class="scroller-item border">
                    {% if item.image %}
                    <img src="{{ item.image|optimized_cloudinary_url:'f_auto,q_auto,c_fill,w_900,h_560' }}"
                        class="media-cover" loading="lazy" decoding="async" sizes="(min-width: 1024px) 56vw, 92vw"
                        alt="Gallery image">
                    {% else %}
                    <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                        No Image
                    </div>
                    {% endif %}
                </div>
                {% endfor %}

            </div>

            <!-- DESCRIPTION -->
            <div class="glass-card p-10">
                <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)] mb-6">
                    Overview
                </h3>

                <div class="text-lg opacity-80">
                    {{ rental.description|linebreaks|default:"No description available." }}
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-4 space-y-6">

            <!-- SPECIFICATIONS -->
            <div class="glass-card p-8">
                <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)] mb-6">
                    Specifications
                </h3>

                <div class="grid grid-cols-2 gap-4">

                    <div class="border rounded-xl p-4 text-center">
                        <i class="fa-solid fa-house text-2xl mb-2"></i>
                        <p class="text-xs font-bold">{{ rental.get_property_type_display }}</p>
                        <p class="text-[10px] opacity-50">Type</p>
                    </div>

                    <div class="border rounded-xl p-4 text-center">
                        <i class="fa-solid fa-couch text-2xl mb-2"></i>
                        <p class="text-xs font-bold">{{ rental.get_furnishing_display }}</p>
                        <p class="text-[10px] opacity-50">Furnishing</p>
                    </div>

                    <div class="border rounded-xl p-4 text-center">
                        <i class="fa-solid fa-bed text-2xl mb-2"></i>
                        <p class="text-xs font-bold">{{ rental.bedrooms|default:"--" }}</p>
                        <p class="text-[10px] opacity-50">Bedrooms</p>
                    </div>

                    <div class="border rounded-xl p-4 text-center">
                        <i class="fa-solid fa-bath text-2xl mb-2"></i>
                        <p class="text-xs font-bold">{{ rental.bathrooms|default:"--" }}</p>
                        <p class="text-[10px] opacity-50">Bathrooms</p>
                    </div>

                </div>
            </div>

            <!-- OWNER -->
            <div class="glass-card p-8 flex items-center gap-5">

                <div class="w-14 h-14 rounded-xl bg-black text-white flex items-center justify-center font-black">
                    <i class="fa-solid fa-user"></i>
                </div>

                <div>
                    <p class="text-[9px] uppercase opacity-40">Listed by</p>
                    <p class="text-xl font-black">
                        {{ rental.user.first_name|default:rental.user.email }}
                    </p>
                    <p class="text-xs opacity-60">
                        {{ rental.user.email }}
                    </p>
                </div>

            </div>

            <!-- SHARE SECTION (FIXED & IMPROVED) -->
            <div class="glass-card p-8 space-y-4">

                <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)]">
                    Share Property
                </h3>

                <!-- Copy Link -->
                <div class="flex gap-2">
                    <input type="text" id="shareLink" value="{{ request.build_absolute_uri }}" readonly
                        class="w-full p-3 text-xs rounded-lg border bg-transparent">

                    <button onclick="copyLink()" class="px-4 py-2 text-xs font-black bg-black text-white rounded-lg">
                        Copy
                    </button>
                </div>

                <!-- Social Buttons -->
                <div class="flex flex-wrap gap-2 text-xs font-bold">

                    <a class="px-3 py-2 rounded-lg bg-green-500 text-white"
                        href="https://wa.me/?text={{ request.build_absolute_uri }}" target="_blank">
                        WhatsApp
                    </a>

                    <a class="px-3 py-2 rounded-lg bg-blue-600 text-white"
                        href="https://www.facebook.com/sharer/sharer.php?u={{ request.build_absolute_uri }}"
                        target="_blank">
                        Facebook
                    </a>

                    <a class="px-3 py-2 rounded-lg bg-black text-white"
                        href="https://twitter.com/intent/tweet?url={{ request.build_absolute_uri }}&text={{ rental.title }}"
                        target="_blank">
                        X
                    </a>

                </div>
            </div>

            <!-- CONTACT -->
            <div class="glass-card p-8 space-y-4">

                <h4 class="text-[10px] font-black text-[var(--accent)] uppercase">
                    Full Address
                </h4>

                <p class="text-sm font-bold opacity-70">
                    {{ rental.address|default:rental.location }}
                </p>

                <a href="{% url 'rental_contact' rental.id %}"
                    class="btn-pro w-full py-5 flex items-center justify-center gap-2">
                    <i class="fa-solid fa-phone"></i>
                    Contact Owner
                </a>

            </div>

        </div>
    </div>
</div>

<!-- JS -->
<script>
    function copyLink() {
        const input = document.getElementById("shareLink");
        input.select();
        input.setSelectionRange(0, 99999);
        document.execCommand("copy");
        alert("Link copied!");
    }
</script>

<script>
function toggleWishlist(btn) {
    const rentalId = btn.dataset.rentalId;
    const csrf = btn.dataset.csrf;
    const isWishlisted = btn.dataset.wishlisted === '1';

    const icon = document.getElementById('wishlist-icon');
    const label = document.getElementById('wishlist-label');

    if (isWishlisted) {
        icon.className = 'fa-regular fa-heart';
        label.textContent = 'Save';
        btn.dataset.wishlisted = '0';
    } else {
        icon.className = 'fa-solid fa-heart text-red-500';
        label.textContent = 'Saved';
        btn.dataset.wishlisted = '1';
    }

    fetch(`/wishlist/toggle/${rentalId}/`, {
        method: 'POST',
        headers: {
            'X-CSRFToken': csrf,
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `csrfmiddlewaretoken=${csrf}`
    }).catch(() => {
        if (isWishlisted) {
            icon.className = 'fa-solid fa-heart text-red-500';
            label.textContent = 'Saved';
            btn.dataset.wishlisted = '1';
        } else {
            icon.className = 'fa-regular fa-heart';
            label.textContent = 'Save';
            btn.dataset.wishlisted = '0';
        }
    });
}
</script>

{% endblock %}
</file>

<file path="render.yaml">
# 1. Databases are declared in their own top-level list
databases:
  - name: Empire Estate-db
    plan: free
    databaseName: rental_db
    user: rental_admin # 🌟 Changed from "postgres" to a valid custom username
# 2. Services (Web apps, workers, etc.) are declared here
services:
  - type: web
    name: Empire Estate-web
    plan: free
    runtime: python
    buildCommand: "./build.sh"
    startCommand: "gunicorn rental_app.wsgi:application --config gunicorn.conf.py"
    envVars:
      - key: PYTHON_VERSION
        value: 3.11.10
      - key: DJANGO_SETTINGS_MODULE
        value: rental_app.settings
      - key: DJANGO_DEBUG
        value: "False"

      # This links securely to the database block declared above
      - key: DATABASE_URL
        fromDatabase:
          name: Empire Estate-db
          property: connectionString

      # Cloudinary Credentials (values input via Render Dashboard)
      - key: CLOUDINARY_CLOUD_NAME
        sync: false
      - key: CLOUDINARY_API_KEY
        sync: false
      - key: CLOUDINARY_API_SECRET
        sync: false

      # Google Social Auth Credentials
      - key: GOOGLE_CLIENT_ID
        sync: false
      - key: GOOGLE_CLIENT_SECRET
        sync: false

      # Security Keys
      - key: SECRET_KEY
        generateValue: true
      - key: DJANGO_ALLOWED_HOSTS
        value: "localhost,127.0.0.1,rentalpro-web.onrender.com,.onrender.com"
      - key: DJANGO_SITE_DOMAIN
        value: "rentalpro-web.onrender.com"
      - key: RENDER_EXTERNAL_HOSTNAME
        sync: false
      - key: DJANGO_CONN_MAX_AGE
        value: "600"
</file>

