@import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap");

:root {
  /* High-Contrast Monochrome Palette */
  --bg: #000000;
  --surface: #0a0a0a;
  --panel: #111111;
  --panel-border: rgba(255, 255, 255, 0.08);
  --panel-strong: rgba(255, 255, 255, 0.12);
  --text: #ffffff;
  --muted: #666666;
  --accent: #ffffff;
  --accent-soft: rgba(255, 255, 255, 0.05);
  --shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
}

body {
  font-family: "Inter", system-ui, -apple-system, sans-serif;
  background-color: var(--bg);
  background-image: none; /* Removed the radial blurs */
  color: var(--text);
  margin: 0;
}

/* Header & Identity */
#header {
  background: var(--bg);
  border-bottom: 1px solid var(--panel-border);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  padding: 0.75rem 1.5rem;
}

#branding h1 {
  font-weight: 900;
  letter-spacing: -0.03em;
  text-transform: uppercase;
  font-size: 1rem;
}

#branding a {
  color: var(--text);
  text-decoration: none;
}

/* Dashboard & Modules */
#content-main,
.module,
.change-form,
.change-form-box,
.app-list {
  background: var(--surface) !important;
  border: 1px solid var(--panel-border) !important;
  border-radius: 12px;
  box-shadow: var(--shadow);
  backdrop-filter: none; /* Clearer SaaS look */
  margin-bottom: 2rem;
}

.module caption,
.grp-module h2,
.change-form h2 {
  background: #161616 !important;
  color: var(--muted) !important;
  font-weight: 800;
  letter-spacing: 0.1em;
  font-size: 0.65rem;
  text-transform: uppercase;
  padding: 1rem 1.5rem;
  border-bottom: 1px solid var(--panel-border);
}

/* Data Tables */
#result_list th {
  background: #161616;
  color: var(--muted);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 1rem;
}

#result_list td {
  border-bottom: 1px solid var(--panel-border);
  padding: 1rem;
  font-size: 0.85rem;
  color: #e0e0e0;
}

#result_list tbody tr:hover {
  background: rgba(255, 255, 255, 0.03);
}

/* Buttons: Solid Monochrome */
.button,
input[type="submit"],
.submit-row input[type="submit"],
.button.default {
  border-radius: 6px;
  background: #ffffff !important;
  color: #000000 !important;
  font-weight: 800;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.8rem 1.5rem;
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
}

.button:hover,
input[type="submit"]:hover {
  background: #e0e0e0 !important;
  transform: translateY(-1px);
}

/* Forms & Inputs */
input,
select,
textarea,
.select-filter {
  border-radius: 8px;
  border: 1px solid var(--panel-border);
  background: #111111;
  color: var(--text);
  padding: 0.75rem;
}

input:focus,
select:focus {
  outline: none;
  border-color: #444444;
  box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.05);
}

/* Specialized Components */
.admin-status-indicator {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  font-size: 9px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.status-dot {
  width: 6px;
  height: 6px;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
}
